{
  "version": 2,
  "outputDirectory": "public",

  "headers": [
    {
      "source": "/koleksi/(.*)\\.jpg",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=100, s-maxage=300, stale-while-revalidate"
        }
      ]
    },
    {
      "source": "/koleksi/(.*)\\.png",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=100, s-maxage=300, stale-while-revalidate"
        }
      ]
    },
    {
      "source": "/koleksi/(.*)\\.mp4",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, s-maxage=300, stale-while-revalidate"
        }
      ]
    }
  ]
}
